# Nexus-PM Agent Environment Configuration
# Copy this file to .env and fill in your actual credentials

# ===== Python Configuration =====
# Suppress Python version deprecation warnings from Google libraries
PYTHONWARNINGS=ignore::FutureWarning

# ===== Gemini API (Recommended - Simpler Setup) =====
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative: Use GOOGLE_API_KEY instead
# GOOGLE_API_KEY=your_google_api_key_here

# ===== Optional: Vertex AI (Advanced - Requires Service Account) =====
# Only needed if you want to use Vertex AI instead of Gemini API
# Path to your service account key JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Your GCP project ID
# GOOGLE_CLOUD_PROJECT=your-project-id

# GCP region for Vertex AI (default: us-central1)
# VERTEX_AI_LOCATION=us-central1

# ===== Linear API =====
# Linear API key for sprint management
# Get from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Linear workspace/organization ID
LINEAR_WORKSPACE_ID=your-workspace-id

# ===== GitHub API =====
# GitHub personal access token with repo scope
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository in format: owner/repo
GITHUB_REPO=your-org/your-repo

# ===== Workflow Configuration =====
# How often to run monitoring loop (in hours)
MONITOR_INTERVAL_HOURS=4

# Maximum monitoring iterations before stopping (42 = 7 days)
MAX_MONITOR_ITERATIONS=42

# ===== Logging =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== Optional: Bob IDE Integration =====
# Bob mode slug for custom mode configuration
BOB_MODE_SLUG=nexus-pm

# ===== Optional: Database =====
# SQLite database path for checkpointer
CHECKPOINT_DB_PATH=./nexus_pm.db